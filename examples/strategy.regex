event {
    x: int;
    y: char;
    ts: int;
}

pred P_x_big = (x > 100);
pred P_x_small = (x < 20);

pred P_y_a = (y == 'a');
pred P_y_b = (y == 'b');
pred P_y_c = (y == 'c');

pred P1 = P_x_big && P_y_a;
pred P2 = P_x_big && P_y_b;
pred P3 = P_x_small && (P_y_b || P_y_c);

regex R1 = (P1 | P2*) . P3
